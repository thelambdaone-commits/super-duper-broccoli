{
  "version": 1,
  "source_inspirations": [
    "TauricResearch/TradingAgents multi-agent trading firm workflow",
    "GitHub agentic CI guidance for explicit handoffs and validation"
  ],
  "decision_pipeline": [
    {
      "phase": "analyst_team",
      "agents": ["market_microstructure_analyst", "sentiment_analyst", "onchain_flow_analyst"],
      "required_outputs": ["market_context", "edge_hypothesis", "data_quality_flags"],
      "hard_gates": ["no_secret_output", "source_timestamp_present"]
    },
    {
      "phase": "research_debate",
      "agents": ["bull_researcher", "bear_researcher", "research_manager"],
      "required_outputs": ["bull_case", "bear_case", "manager_verdict"],
      "hard_gates": ["both_sides_present", "confidence_is_bounded"]
    },
    {
      "phase": "trader_synthesis",
      "agents": ["trader_agent"],
      "required_outputs": ["side", "limit_price", "time_in_force", "expected_edge"],
      "hard_gates": ["paper_first", "price_bounds_valid"]
    },
    {
      "phase": "risk_management",
      "agents": ["aggressive_risk", "neutral_risk", "conservative_risk", "portfolio_manager"],
      "required_outputs": ["position_size", "kill_switch_state", "portfolio_impact"],
      "hard_gates": ["ledger_reserve_required", "circuit_breaker_allows", "mode_guard_allows"]
    },
    {
      "phase": "execution_handoff",
      "agents": ["execution_engineer"],
      "required_outputs": ["order_plan", "fallback_plan", "post_trade_checks"],
      "hard_gates": ["no_direct_llm_execution", "deterministic_executor_only"]
    }
  ],
  "rating_scale": {
    "strong_buy": 2,
    "buy": 1,
    "neutral": 0,
    "sell": -1,
    "strong_sell": -2
  },
  "trace_milestones": [
    "ingest_signal",
    "analyst_context_ready",
    "research_debate_completed",
    "trader_plan_created",
    "risk_gate_passed",
    "ledger_reserved",
    "execution_submitted",
    "post_trade_recorded"
  ]
}
