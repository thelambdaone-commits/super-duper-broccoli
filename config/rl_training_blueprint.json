{
  "version": 1,
  "source_inspirations": [
    "Unity ML-Agents PPO/SAC/self-play/curriculum patterns",
    "LOBSTAR paper execution and risk guardrails"
  ],
  "environment": {
    "name": "lobstar_market_sim",
    "episode_end_conditions": [
      "max_steps_reached",
      "daily_loss_limit_hit",
      "market_closed",
      "liquidity_stale"
    ],
    "observations": [
      "mid_price",
      "spread_bps",
      "order_imbalance",
      "liquidity_score",
      "volatility_regime",
      "portfolio_exposure",
      "ledger_available_capital",
      "recent_slippage_bps"
    ],
    "actions": [
      "hold",
      "quote_passive_buy",
      "quote_passive_sell",
      "take_buy",
      "take_sell",
      "cancel_orders",
      "reduce_exposure"
    ]
  },
  "reward": {
    "positive": {
      "realized_pnl": 1.0,
      "maker_fill_without_adverse_selection": 0.25,
      "risk_adjusted_return": 0.5
    },
    "negative": {
      "drawdown": -1.0,
      "slippage_bps": -0.2,
      "stale_data_trade": -2.0,
      "risk_gate_violation": -5.0
    }
  },
  "training_modes": {
    "ppo": {
      "use_case": "stable policy learning in paper market replay",
      "default": true
    },
    "sac": {
      "use_case": "continuous quote aggressiveness tuning",
      "default": false
    },
    "self_play": {
      "use_case": "maker/taker adversarial stress against simulated toxic flow",
      "default": false
    },
    "behavior_cloning": {
      "use_case": "imitate validated profitable paper executions before RL fine-tuning",
      "default": true
    }
  },
  "promotion_gates": [
    "walk_forward_positive_expectancy",
    "max_drawdown_below_limit",
    "calibration_brier_score_improves",
    "trust_layer_trace_passes",
    "paper_mode_minimum_episodes_met"
  ]
}
