###############################################################################
#             🚨 LOBSTAR QUANT AGENTIC TRADING CORE - CONFIG TEMPLATE 🚨       #
###############################################################################
# Copy this file to '.env' and fill in the values below.
# Make sure to keep your secrets secure and never commit real keys to Git!
#
# Path: .env
###############################################################################

# =============================================================================
# 🟢 1. SYSTEM MODE & ENVIRONMENT
# =============================================================================
# REPLAY : Run backtests against historical signal databases
# PAPER  : Virtual trading on live signals (default, safe for dry-run)
# SHADOW : Low-capital real execution (1% mini positions)
# PROD   : Live production algorithmic execution (REAL CAPITAL AT RISK)
EXECUTION_MODE=PAPER

# =============================================================================
# 🔑 2. HASHICORP VAULT SECURE STATE STORAGE
# =============================================================================
# Controls where the bot fetches its credentials. Options: 'vault' or 'env'.
# If 'vault', VAULT_ADDR and VAULT_TOKEN are required.
# If 'env', the bot reads directly from local encrypted files and environment.
SECRET_SOURCE=env

# HashiCorp Vault Server Address (Set to 'false' to bypass Vault entirely)
VAULT_ADDR=http://127.0.0.1:8200
VAULT_TOKEN=hvs.your_vault_token_here

# =============================================================================
# 🤖 3. LLM COUNCIL & MULTI-AGENT SWARM INTEGRATION
# =============================================================================
# Primary LLM provider key for semantic parsing (Groq is the default)
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenRouter API Key is required to enable live multi-agent LLM Council synthesis
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# Optional external LLM provider keys
OPENAI_API_KEY=sk-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# =============================================================================
# 💼 4. CRYPTO WALLETS & ENCRYPTION
# =============================================================================
# Fernet encryption key used to encrypt/decrypt wallet data files.
# Generate a valid Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# Core Polymarket CLOB Execution Private Key (Ethereum Address)
# Strictly required if running in SHADOW or PROD modes, or deriving CLOB API keys
CLOB_PRIVATE_KEY=0x_your_ethereum_private_key_here

# Polymarket CLOB Derived API Credentials (Auto-derived from CLOB_PRIVATE_KEY if empty)
CLOB_API_KEY=your_derived_clob_api_key_here
CLOB_API_SECRET=your_derived_clob_api_secret_here
CLOB_API_PASSPHRASE=your_derived_clob_api_passphrase_here

# =============================================================================
# 📣 5. TELEGRAM BOT & WEBHOOK CONFIGURATION
# =============================================================================
# Telegram Bot API token obtained from @BotFather
TELEGRAM_BOT_TOKEN=123456789:your_telegram_bot_token_here

# Telegram Target Channel / Group ID where signals are broadcasted (e.g., -100...)
CHAT_ID=-1002222224501

# Authorized Private Telegram User/Chat IDs allowed to invoke command controls
# Comma-separated list of numeric chat/user IDs
TELEGRAM_PRIVATE_CHAT_IDS=123456789,987654321

# Enable/Disable private message signal parsing (1=Enabled, 0=Disabled)
TELEGRAM_PRIVATE_ENABLED=1

# =============================================================================
# 💾 6. LOCAL PERSISTENCE & DATABASE PATHS
# =============================================================================
# Directory where DuckDB feature stores, encryptions, and SQLite ledgers reside.
DATA_PATH=data
LOG_PATH=logs

# =============================================================================
# 🛡️ 7. PRODUCTION HEALTH & RESILIENCE CALIBRATION
# =============================================================================
# Staleness threshold for high frequency streams (Binance WebSocket feed)
MAX_BINANCE_STALENESS_SECONDS=3.0

# Staleness threshold for low frequency streams (Polymarket order books)
MAX_POLYMARKET_STALENESS_SECONDS=60.0

# Process RAM threshold in Megabytes to trigger autonomic garbage collection
MAX_MEMORY_MB_THRESHOLD=1024

# Maximum allowed financial balance drift between SQLite ledger and on-chain USDC
MAX_WALLET_DRIFT_USDC=0.01

